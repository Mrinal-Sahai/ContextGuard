# ContextGuard — Environment Variables
# ======================================
# Copy this file to .env and fill in your real values.
# .env is gitignored and will never be committed.
#
#   cp .env.example .env
#
# Then start the stack:
#   docker compose up --build

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal Access Token (classic) with repo + read:org scopes
# Without token: public repos only, 60 req/hr rate limit
# With token:    private repos supported, 5000 req/hr rate limit
GITHUB_TOKEN=ghp_your_token_here

# Optional: secondary token (e.g. for webhook signature verification)
# GITHUB_TOKEN_SECRET=github_pat_your_secret_here

# ── GitHub OAuth App (for "Sign in with GitHub" feature) ─────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Homepage URL:               http://localhost:3000
# Authorization callback URL: http://localhost:8080/api/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=_...your_client_id_here...
GITHUB_OAUTH_CLIENT_SECRET=_...your_client_secret_here...

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=contextguard-dev-secret-key-change-in-production-min-32chars

# ── Frontend URL (OAuth redirect target after login) ─────────────────────────
FRONTEND_URL=http://localhost:3000

# OpenAI — required if LLM_PROVIDER=openai
OPENAI_API_KEY=sk-proj-...your_key_here...
# Gemini — required if LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here

# ── Database (docker-compose defaults — change for production) ────────────────
# POSTGRES_PASSWORD=cgpass

# ── Optional: Webhook secrets ─────────────────────────────────────────────────
# GITHUB_WEBHOOK_SECRET=your_webhook_secret
